APP_ENV=development
LOG_LEVEL=INFO
SERVICE_NAME=surveillance_app

# -- Database -----------------------------------------------------------------
DB_HOST=postgres
DB_PORT=5432
DB_NAME=surveillance_db
DB_USER=surveillance_user
DB_PASSWORD=surveillance_pass

# -- Ollama -------------------------------------------------------------------
OLLAMA_HOST=http://ollama:11434

# Vision model -- optional Phase 6B enrichment for selected tracks
# Default for CPU-first live mode: use a small model, not minicpm-v.
MULTIMODAL_MODEL=moondream:1.8b
#MULTIMODAL_MODEL=minicpm-v:latest
#MULTIMODAL_MODEL=llava:7b

# Text model -- Q&A ( later can use good reasoning model for Q&A and a smaller one for summarization )
TEXT_MODEL=llama3.2:latest

# Summary model -- separate from Q&A for easier tuning
AUTO_SUMMARIZE=false
SUMMARY_MODEL=llama3.2:latest
SUMMARY_NUM_CTX=2048
SUMMARY_MAX_TOKENS=300
SUMMARY_TRACK_LIMIT=6
ASK_TIMEOUT_SECONDS=480
SUMMARY_TIMEOUT_SECONDS=420
QA_TOP_K_TEMPORAL=6
QA_TOP_K_OBJECT=6
OLLAMA_CONCURRENCY=1

# Embedding model -- semantic search (768-dim vectors)
EMBED_MODEL=nomic-embed-text

# -- Captioning ---------------------------------------------------------------
CAPTION_TIMEOUT_SECONDS=300
CAPTION_MAX_TOKENS=512
CAPTION_MAX_IMAGE_DIM=768

# -- Frame sampling -----------------------------------------------------------
FRAME_SAMPLE_FPS=2

# -- Scene change detection ---------------------------------------------------
SCENE_CHANGE_THRESHOLD=25
SCENE_LONG_WINDOW_SECONDS=8
SCENE_LONG_WINDOW_THRESHOLD=25.0
SCENE_COOLDOWN_SECONDS=3

# -- Phase 6A: YOLO Detection -------------------------------------------------
YOLO_MODEL=yolov8n.pt
YOLO_MODEL_PATH=
YOLO_CONFIDENCE_THRESHOLD=0.45

# -- Phase 6A: Event Generation ----------------------------------------------
DWELL_THRESHOLD_SECONDS=10.0
EXIT_GAP_SECONDS=3.0
CROP_MIN_CONFIDENCE=0.5

# -- Phase 6A: Track Quality Filters -----------------------------------------
MIN_VISIBLE_FRAMES=3
MERGE_GAP_SECONDS=30

# -- Phase 6B: Attribute Extraction ------------------------------------------
ENABLE_PHASE_6B=true
ATTRIBUTE_POLICY=selective
ENABLE_ACTIVITY_CAPTIONS=false
ENABLE_PLATE_OCR=false
ATTRIBUTE_MIN_DURATION_SECONDS=8
ATTRIBUTE_MAX_TRACKS_PER_WINDOW=4

# -- Source: change only this line between live and batch ---------------------
# LIVE mode  -> set to your RTSP URL. The system auto-detects, starts stream,
#               creates 5-minute windows, and runs post-processing automatically.
# BATCH mode -> set to a file or folder path.
VIDEO_INPUT_PATH=
#VIDEO_INPUT_PATH=/app/data/
#VIDEO_INPUT_PATH=/app/data/test_video4.mp4

# -- Camera ID ----------------------------------------------------------------
# e.g. gate_cam_01_20260305_1600
CAMERA_ID=gate_cam_01

# -- Live stream tuning -------------------------------------------------------
LIVE_WINDOW_MINUTES=5

# Frames per second to sample for YOLO detection
# 2 = detect every 0.5s — good for office door cam
# Lower to 1 if CPU is overloaded
LIVE_SAMPLE_FPS=2

# MJPEG stream JPEG quality for browser display
LIVE_STREAM_JPEG_QUALITY=75

# Seconds of no detection before person is marked as exited
LIVE_EXIT_TIMEOUT_SECONDS=8

# ReID similarity threshold (0.0–1.0)
# 0.72 = reliable same-person match in single-camera scene
# Lower → easier to match returning person (more false merges)
# Raise → stricter matching (more new IDs assigned)
LIVE_REID_THRESHOLD=0.72

# -- Ask vs Pipeline Ollama concurrency (fix45) --------------------------------
ASK_LANE_TIMEOUT_SECONDS=130   # how long Ask waits if pipeline holds Ollama
ASK_OLLAMA_CONCURRENCY=1       # max concurrent Ask calls (keep 1 for 1-GPU)
PIPELINE_OLLAMA_CONCURRENCY=1  # max concurrent pipeline calls (keep 1 for 1-GPU)